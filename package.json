{
  "name": "tyrads-sdk-qa-automation",
  "version": "1.0.0",
  "private": true,
  "description": "QA automation assignment for TyrAds SDK web iframe, API, and Android example app.",
  "scripts": {
    "test": "npm run test:web",
    "test:web": "playwright test tests/web",
    "test:e2e": "playwright test tests/web tests/api",
    "test:api": "playwright test tests/api",
    "test:mobile": "wdio run wdio.conf.ts",
    "record:mobile": "wdio run wdio.conf.ts --spec tests/mobile/offerwall.spec.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.14.0",
    "@wdio/appium-service": "^8.39.1",
    "@wdio/cli": "^8.40.0",
    "@wdio/globals": "^8.40.0",
    "@wdio/local-runner": "^8.40.0",
    "@wdio/mocha-framework": "^8.39.0",
    "@wdio/spec-reporter": "^8.39.0",
    "appium": "^2.9.0",
    "appium-uiautomator2-driver": "^4.2.9",
    "dotenv": "^16.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0",
    "webdriverio": "^8.40.0"
  }
}
